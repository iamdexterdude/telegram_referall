# ─────────────────────────────────────────────
#  Telegram Bot Configuration
# ─────────────────────────────────────────────
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
BOT_USERNAME=your_bot_username

# Channel users must join (e.g. @mychannel or -1001234567890)
CHANNEL_ID=@your_channel

# ─────────────────────────────────────────────
#  Database
# ─────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./referral_bot.db

# ─────────────────────────────────────────────
#  Bot Behaviour
# ─────────────────────────────────────────────
LEADERBOARD_LIMIT=10

# Admin Telegram user IDs (comma-separated)
ADMIN_IDS=123456789

# Welcome banner image URL (optional — leave empty to skip)
WELCOME_IMAGE_URL=
